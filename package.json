{
  "name": "chatgraph-vercel-prototype",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "npm run test:gate && npm run test:results && npm run test:paper",
    "test:gate": "node --import ./scripts/ts-alias-hooks.mjs --no-warnings src/test/js/gate_conformance.mjs",
    "test:results": "node scripts/nesy_results/validate_results.mjs",
    "ablation": "node --import ./scripts/ts-alias-hooks.mjs scripts/nesy_results/run_gated_ablation.mjs",
    "results:build": "node --import ./scripts/ts-alias-hooks.mjs scripts/nesy_results/build_results_package.mjs",
    "test:paper": "node scripts/nesy_results/verify_paper_claims.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "d3-force": "^3.0.0",
    "lucide-react": "^0.468.0",
    "next": "^15.3.0",
    "openai": "^6.42.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.29.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.3.0",
    "typescript": "^5.7.0"
  }
}
