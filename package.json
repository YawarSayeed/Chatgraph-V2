{
  "name": "chatgraph-vercel-prototype",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "npm run test:gate && npm run test:results",
    "test:gate": "node --import ./scripts/ts-alias-hooks.mjs --no-warnings src/test/js/gate_conformance.mjs",
    "test:results": "node scripts/nesy_results/validate_results.mjs",
    "ablation:real": "node scripts/nesy_results/run_real_ablation.mjs",
    "results:recover": "node scripts/nesy_results/recover_measured_results.mjs",
    "results:judge-a0": "node scripts/nesy_results/judge_recovered_a0.mjs A0",
    "results:judge-a5": "node scripts/nesy_results/judge_recovered_a0.mjs A5",
    "results:audit": "node scripts/nesy_results/ingest_human_audit.mjs",
    "results:finalize": "npm run results:recover"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "d3-force": "^3.0.0",
    "lucide-react": "^0.468.0",
    "next": "^15.3.0",
    "openai": "^6.42.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.29.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.3.0",
    "typescript": "^5.7.0"
  }
}
